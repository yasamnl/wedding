<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>The Wedding of Ziya & Thohirin</title>
  
  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Cormorant+Garamond:wght@400;600;700&family=Poppins:wght@300;400;500&display=swap" rel="stylesheet">
  
  <style>
    /* --- RESET & VARIABLES --- */
    :root {
      --primary-color: #1a2a4a;
      --accent-gold: #c4a882;
      --text-dark: #2c2c2c;
      --bg-overlay: rgba(255, 255, 255, 0.88);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body { 
      font-family: 'Poppins', sans-serif; 
      color: var(--text-dark); 
      overflow-x: hidden;
      background-color: #f0f0f0;
    }

    /* --- BACKGROUND CUSTOM IMAGE --- */
    .custom-bg {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -2;
      /* GANTI URL INI DENGAN LINK GAMBAR BACKGROUND ANDA */
      background-image: url('https://images.unsplash.com/photo-1579783902614-a3fb3927b6a5?q=80&w=2545&auto=format&fit=crop'); 
      background-size: cover; background-position: center; background-attachment: fixed;
    }

    .bg-overlay {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1;
      background: var(--bg-overlay); backdrop-filter: blur(2px);
    }

    /* --- ORNAMEN BUNGA POJOK --- */
    .corner-flower {
      position: absolute; width: 160px; height: 160px; z-index: 10; pointer-events: none; opacity: 0.9;
    }
    .corner-flower img { width: 100%; height: 100%; object-fit: contain; }
    .top-left { top: -10px; left: -10px; }
    .top-right { top: -10px; right: -10px; transform: scaleX(-1); }
    .bottom-left { bottom: -10px; left: -10px; transform: scaleY(-1); }
    .bottom-right { bottom: -10px; right: -10px; transform: scale(-1, -1); }

    /* --- COVER SECTION --- */
    .cover {
      min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;
      position: relative; padding: 40px 20px;
    }
    .cover-content { z-index: 2; animation: fadeInUp 1.5s ease-out; position: relative; max-width: 600px; width: 100%; }
    
    .cover-label { font-size: 13px; letter-spacing: 4px; text-transform: uppercase; color: var(--primary-color); margin-bottom: 15px; font-weight: 600; }
    .cover-names { font-family: 'Great Vibes', cursive; font-size: clamp(55px, 14vw, 90px); color: var(--primary-color); line-height: 1; text-shadow: 2px 2px 4px rgba(255,255,255,0.6); margin: 5px 0; }
    .cover-amp { font-family: 'Great Vibes', cursive; font-size: 35px; color: var(--accent-gold); display: block; margin: 0 auto; }
    .cover-date { font-family: 'Cormorant Garamond', serif; font-size: 20px; letter-spacing: 6px; color: var(--primary-color); margin-top: 15px; margin-bottom: 30px; font-weight: 700; }
    
    .btn-open {
      padding: 15px 45px; background: var(--primary-color); border: none; color: #fff;
      font-family: 'Poppins', sans-serif; font-size: 13px; letter-spacing: 2px; text-transform: uppercase; cursor: pointer;
      transition: all 0.3s ease; border-radius: 50px; box-shadow: 0 10px 20px rgba(26, 42, 74, 0.2);
    }
    .btn-open:hover { background: #2d4a7a; transform: translateY(-3px); }

    /* --- MAIN CONTENT --- */
    .main-content { display: none; max-width: 800px; margin: 0 auto; position: relative; z-index: 5; padding-bottom: 50px; }
    section { padding: 60px 20px; position: relative; }
    .section-title { font-family: 'Cormorant Garamond', serif; font-size: 34px; color: var(--primary-color); margin-bottom: 10px; text-align: center; }
    .section-subtitle { font-size: 12px; color: #666; letter-spacing: 3px; text-transform: uppercase; margin-bottom: 40px; text-align: center; }

    /* --- HERO & QUOTE --- */
    .hero { text-align: center; padding: 80px 20px; }
    .hero-names { font-family: 'Great Vibes', cursive; font-size: clamp(45px, 11vw, 80px); color: var(--primary-color); line-height: 1.2; }
    .hero-amp { font-family: 'Great Vibes', cursive; font-size: 35px; color: var(--accent-gold); display: block; margin: 10px 0; }
    
    .quote-section { text-align: center; background: rgba(255,255,255,0.6); margin: 20px; border-radius: 20px; padding: 40px 20px; border: 1px solid rgba(255,255,255,0.8); }
    .quote-text { font-family: 'Cormorant Garamond', serif; font-size: 19px; font-style: italic; color: #444; line-height: 1.8; max-width: 600px; margin: 0 auto; }
    .quote-source { font-size: 13px; color: var(--primary-color); margin-top: 20px; font-weight: 700; letter-spacing: 1px; }

    /* --- COUPLE SECTION (KUPU-KUPU) --- */
    .couple-section { overflow: hidden; }
    .couple-container { display: flex; justify-content: center; gap: 30px; flex-wrap: wrap; align-items: center; position: relative; z-index: 2; }
    .couple-card { flex: 1; min-width: 240px; max-width: 280px; text-align: center; background: rgba(255,255,255,0.7); padding: 30px; border-radius: 20px; backdrop-filter: blur(5px); border: 1px solid rgba(255,255,255,0.5); }
    .couple-photo-circle { width: 140px; height: 140px; border-radius: 50%; object-fit: cover; margin: 0 auto 20px; border: 4px solid var(--accent-gold); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
    .couple-name { font-family: 'Great Vibes', cursive; font-size: 38px; color: var(--primary-color); margin-bottom: 10px; }
    .couple-parents { font-size: 13px; color: #555; line-height: 1.6; }
    .couple-divider { font-family: 'Great Vibes', cursive; font-size: 60px; color: var(--accent-gold); opacity: 0.8; }

    /* Animasi Kupu-kupu */
    .butterfly {
      position: absolute; width: 25px; height: 25px;
      background-image: url('data:image/svg+xml;utf8,<svg viewBox="0 0 24 24" fill="%231a2a4a" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C12 2 11 3 11 4C11 5 12 6 12 6C12 6 13 5 13 4C13 3 12 2 12 2ZM8.5 5C7.5 5 6.5 6 6.5 7C6.5 8 7.5 9 8.5 9C9.5 9 10.5 8 10.5 7C10.5 6 9.5 5 8.5 5ZM15.5 5C14.5 5 13.5 6 13.5 7C13.5 8 14.5 9 15.5 9C16.5 9 17.5 8 17.5 7C17.5 6 16.5 5 15.5 5ZM12 7C9 7 6 9 6 12C6 15 9 17 12 17C15 17 18 15 18 12C18 9 15 7 12 7Z"/></svg>');
      background-size: contain; background-repeat: no-repeat; opacity: 0.6; pointer-events: none; z-index: 1;
      animation: fly 15s infinite linear;
    }
    @keyframes fly {
      0% { transform: translate(0, 0) rotate(0deg) scale(0.8); opacity: 0; }
      10% { opacity: 0.8; }
      25% { transform: translate(50px, -50px) rotate(20deg) scale(1); }
      50% { transform: translate(100px, 0) rotate(-10deg) scale(0.9); }
      75% { transform: translate(50px, 50px) rotate(-20deg) scale(1.1); }
      90% { opacity: 0.8; }
      100% { transform: translate(0, 0) rotate(0deg) scale(0.8); opacity: 0; }
    }

    /* --- EVENT & COUNTDOWN --- */
    .event-cards { display: flex; flex-direction: column; gap: 20px; max-width: 600px; margin: 0 auto; }
    .event-card { background: rgba(255,255,255,0.8); padding: 30px; border-radius: 16px; text-align: center; border: 1px solid rgba(255,255,255,0.6); backdrop-filter: blur(10px); }
    .event-type { font-family: 'Cormorant Garamond', serif; font-size: 26px; color: var(--primary-color); margin-bottom: 15px; font-weight: 700; }
    .btn-map { display: inline-block; margin-top: 15px; padding: 10px 25px; background: var(--primary-color); color: #fff; text-decoration: none; border-radius: 25px; font-size: 12px; transition: 0.3s; }
    .btn-map:hover { background: var(--accent-gold); }

    .countdown-section { background: var(--primary-color); color: #fff; border-radius: 20px; margin: 20px; text-align: center; padding: 40px 20px; }
    .countdown-container { display: flex; justify-content: center; gap: 15px; flex-wrap: wrap; margin-top: 30px; }
    .countdown-item { background: rgba(255,255,255,0.1); padding: 15px; border-radius: 12px; min-width: 70px; border: 1px solid rgba(255,255,255,0.2); }
    .countdown-number { font-family: 'Cormorant Garamond', serif; font-size: 32px; font-weight: 700; display: block; }
    .countdown-label { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; opacity: 0.8; }

    /* --- FORMS & GLASS PANEL --- */
    .glass-panel { background: rgba(255,255,255,0.85); padding: 30px 20px; border-radius: 20px; max-width: 500px; margin: 0 auto; border: 1px solid rgba(255,255,255,0.6); backdrop-filter: blur(10px); }
    .cek-input-group { display: flex; gap: 10px; margin-bottom: 20px; }
    .form-input, .cek-input { flex: 1; padding: 12px; border: 1px solid #ccc; border-radius: 10px; outline: none; font-family: 'Poppins'; font-size: 14px; transition: 0.3s; width: 100%; }
    .form-input:focus, .cek-input:focus { border-color: var(--primary-color); box-shadow: 0 0 0 3px rgba(26,42,74,0.1); }
    .btn-action { padding: 12px 20px; background: var(--primary-color); color: #fff; border: none; border-radius: 10px; cursor: pointer; font-weight: 500; font-size: 13px; transition: 0.3s; white-space: nowrap; }
    .btn-action:hover { background: #2d4a7a; }
    
    .result-box { margin-top: 15px; padding: 15px; border-radius: 10px; display: none; text-align: left; font-size: 13px; line-height: 1.6; }
    .result-box.found { background: #e8f5e9; border: 1px solid #a5d6a7; display: block; }
    .result-box.not-found { background: #fce4ec; border: 1px solid #ef9a9a; display: block; }
    .result-box.error { background: #fff3e0; border: 1px solid #ffcc80; display: block; animation: shake 0.4s; }

    /* --- FOOTER --- */
    .footer { text-align: center; padding: 40px 20px; color: var(--primary-color); font-size: 13px; }
    .footer-names { font-family: 'Great Vibes', cursive; font-size: 36px; margin-bottom: 10px; }

    /* --- UTILS --- */
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes shake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-5px); } 75% { transform: translateX(5px); } }
    .scroll-reveal { opacity: 0; transform: translateY(40px); transition: all 1s ease-out; }
    .scroll-reveal.active { opacity: 1; transform: translateY(0); }

    @media (max-width: 600px) {
      .corner-flower { width: 90px; height: 90px; }
      .couple-divider { display: none; }
      .cek-input-group { flex-direction: column; }
      .cover-names { font-size: clamp(45px, 12vw, 70px); }
    }
  </style>
</head>
<body>

  <!-- BACKGROUND LAYERS -->
  <div class="custom-bg"></div>
  <div class="bg-overlay"></div>

  <!-- COVER SECTION -->
  <div class="cover" id="coverSection">
    <!-- Ornamen Pojok Cover -->
    <div class="corner-flower top-left"><img src="https://assets.codepen.io/13471/floral-corner-1.png" alt="flower"></div>
    <div class="corner-flower top-right"><img src="https://assets.codepen.io/13471/floral-corner-1.png" alt="flower"></div>
    <div class="corner-flower bottom-left"><img src="https://assets.codepen.io/13471/floral-corner-1.png" alt="flower"></div>
    <div class="corner-flower bottom-right"><img src="https://assets.codepen.io/13471/floral-corner-1.png" alt="flower"></div>

    <div class="cover-content">
      <div class="cover-label">The Wedding Of</div>
      <div class="cover-names">Ziya</div>
      <span class="cover-amp">&amp;</span>
      <div class="cover-names">Thohirin</div>
      <div class="cover-date">27 . 08 . 2026</div>
      
      <!-- Foto Mempelai di Cover -->
      <div style="width: 140px; height: 140px; margin: 15px auto; border-radius: 50%; overflow: hidden; border: 3px solid #fff; box-shadow: 0 10px 30px rgba(0,0,0,0.2);">
        <img src="https://img.gt.tc/assets/img/zyth.png" style="width:100%; height:100%; object-fit:cover;" alt="Couple">
      </div>

      <!-- ✅ AREA NAMA TAMU UNDANGAN (CUSTOM URL) -->
      <div id="guestNameWrapper" style="margin-bottom: 25px; display: none;">
        <p style="font-size: 12px; color: rgba(255,255,255,0.85); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 5px;">Kepada Yth Bapak/Ibu/Saudara/i</p>
        <h2 id="guestNameDisplay" style="font-family: 'Great Vibes', cursive; font-size: 30px; color: #fff; margin: 0; text-shadow: 0 2px 4px rgba(0,0,0,0.3);"></h2>
      </div>

      <button class="btn-open" onclick="openInvitation()">Buka Undangan</button>
    </div>
  </div>

  <!-- MAIN CONTENT -->
  <div class="main-content" id="mainContent">
    
    <!-- HERO -->
    <section class="hero scroll-reveal">
      <div class="cover-label">The Wedding Of</div>
      <div class="hero-names">Ziya<span class="hero-amp">&amp;</span>Thohirin</div>
      <div class="cover-date">27 AGUSTUS 2026</div>
    </section>

    <!-- QUOTE -->
    <section class="quote-section scroll-reveal">
      <p class="quote-text">
        "Dan di antara tanda-tanda (kebesaran)-Nya ialah Dia menciptakan pasangan-pasangan untukmu dari jenismu sendiri, agar kamu cenderung dan merasa tenteram kepadanya..."
      </p>
      <p class="quote-source">(QS. Ar-Rum: 21)</p>
    </section>

    <!-- COUPLE SECTION (TARGET KUPU-KUPU) -->
    <section class="couple-section scroll-reveal" id="coupleArea">
      <h2 class="section-title">Mempelai</h2>
      <p class="section-subtitle">Insya Allah Akan Melangsungkan Pernikahan</p>
      
      <div class="couple-container">
        <div class="couple-card">
          <img src="https://images.unsplash.com/photo-1544005313-94ddf0286df2?ixlib=rb-4.0.3&auto=format&fit=crop&w=300&q=80" class="couple-photo-circle" alt="Ziya">
          <div class="couple-name">Ziya</div>
          <p class="couple-parents">Putri dari<br><strong>Bapak ... & Ibu ...</strong></p>
        </div>
        
        <div class="couple-divider">&amp;</div>
        
        <div class="couple-card">
          <img src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?ixlib=rb-4.0.3&auto=format&fit=crop&w=300&q=80" class="couple-photo-circle" alt="Thohirin">
          <div class="couple-name">Thohirin</div>
          <p class="couple-parents">Putra dari<br><strong>Bapak ... & Ibu ...</strong></p>
        </div>
      </div>
    </section>

    <!-- EVENT DETAILS -->
    <section class="scroll-reveal">
      <h2 class="section-title">Detail Acara</h2>
      <div class="event-cards">
        <div class="event-card">
          <div class="event-type">Akad Nikah</div>
          <p>Kamis, 27 Agustus 2026 | 08:00 WIB</p>
          <p>Masjid Agung Al-Hikmah</p>
          <a href="#" class="btn-map">Lihat Peta</a>
        </div>
        <div class="event-card">
          <div class="event-type">Resepsi</div>
          <p>Kamis, 27 Agustus 2026 | 11:00 - Selesai</p>
          <p>Gedung Serbaguna Kota</p>
          <a href="#" class="btn-map">Lihat Peta</a>
        </div>
      </div>
    </section>

    <!-- COUNTDOWN -->
    <section class="countdown-section scroll-reveal">
      <h2 class="section-title" style="color:#fff;">Menuju Hari Bahagia</h2>
      <div class="countdown-container">
        <div class="countdown-item"><span class="countdown-number" id="cd-days">00</span><div class="countdown-label">Hari</div></div>
        <div class="countdown-item"><span class="countdown-number" id="cd-hours">00</span><div class="countdown-label">Jam</div></div>
        <div class="countdown-item"><span class="countdown-number" id="cd-minutes">00</span><div class="countdown-label">Menit</div></div>
        <div class="countdown-item"><span class="countdown-number" id="cd-seconds">00</span><div class="countdown-label">Detik</div></div>
      </div>
    </section>

    <!-- CEK NAMA TAMU -->
    <section class="scroll-reveal">
      <h2 class="section-title">Cek Nama Tamu</h2>
      <div class="glass-panel">
        <div class="cek-input-group">
          <input type="text" class="cek-input" id="cekInput" placeholder="Masukkan nama Anda...">
          <button class="btn-action" id="btnCek" onclick="cekNama()">Cek</button>
        </div>
        <div class="result-box" id="cekResult"></div>
      </div>
    </section>

    <!-- KONFIRMASI -->
    <section class="scroll-reveal">
      <h2 class="section-title">Konfirmasi Kehadiran</h2>
      <div class="glass-panel">
        <div style="margin-bottom:15px;">
          <label style="display:block;margin-bottom:5px;font-size:12px;font-weight:600;">NAMA</label>
          <input type="text" class="form-input" id="confNama" style="width:100%;">
        </div>
        <div style="margin-bottom:15px;">
          <label style="display:block;margin-bottom:5px;font-size:12px;font-weight:600;">KEHADIRAN</label>
          <select class="form-input" id="confStatus" style="width:100%;">
            <option value="✅ Hadir">Hadir</option>
            <option value="❌ Tidak Hadir">Tidak Hadir</option>
          </select>
        </div>
        <div style="margin-bottom:15px;">
          <label style="display:block;margin-bottom:5px;font-size:12px;font-weight:600;">UCAPAN</label>
          <textarea class="form-input" id="confUcapan" rows="3" style="width:100%;resize:none;"></textarea>
        </div>
        <button class="btn-action" style="width:100%;" id="btnSubmit" onclick="kirimKonfirmasi()">Kirim Konfirmasi</button>
        <div class="result-box" id="submitResult" style="margin-top:15px;"></div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="footer scroll-reveal">
      <div class="footer-names">Ziya & Thohirin</div>
      <p>Terima kasih atas doa dan restunya</p>
    </footer>

  </div>

  <!-- JAVASCRIPT LOGIC -->
  <script>
    // 1. CUSTOM GUEST NAME FROM URL
    function initGuestName() {
      const urlParams = new URLSearchParams(window.location.search);
      const guestParam = urlParams.get('to'); 
      
      if (guestParam) {
        const wrapper = document.getElementById('guestNameWrapper');
        const display = document.getElementById('guestNameDisplay');
        
        // Format: ganti '-' dengan spasi & Capitalize setiap kata
        const formattedName = guestParam
          .replace(/-/g, ' ')
          .replace(/\b\w/g, char => char.toUpperCase());
          
        display.textContent = formattedName;
        wrapper.style.display = 'block';
        
        // Auto-isi form konfirmasi
        const confInput = document.getElementById('confNama');
        if(confInput) confInput.value = formattedName;
      }
    }

    // 2. OPEN INVITATION
    function openInvitation() {
      document.getElementById('coverSection').style.display = 'none';
      const main = document.getElementById('mainContent');
      main.style.display = 'block';
      
      setTimeout(() => {
        document.querySelectorAll('.scroll-reveal').forEach(el => el.classList.add('active'));
        startButterflies();
      }, 100);
      
      startCountdown();
    }

    // 3. SCROLL ANIMATION OBSERVER
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('active');
      });
    }, { threshold: 0.1 });

    // 4. BUTTERFLY ANIMATION
    function startButterflies() {
      const container = document.getElementById('coupleArea');
      if(!container) return;
      for(let i=0; i<6; i++) createButterfly(container, i * 2000);
    }

    function createButterfly(parent, delay) {
      const b = document.createElement('div');
      b.className = 'butterfly';
      b.style.left = (Math.random() * 80 + 10) + '%';
      b.style.top = (Math.random() * 80 + 10) + '%';
      b.style.animationDelay = (delay / 1000) + 's';
      const size = 20 + Math.random() * 15;
      b.style.width = size + 'px';
      b.style.height = size + 'px';
      parent.appendChild(b);
    }

    // 5. COUNTDOWN TIMER
    function startCountdown() {
      const target = new Date('2026-08-27T08:00:00').getTime();
      setInterval(() => {
        const now = new Date().getTime();
        const dist = target - now;
        if(dist < 0) return;
        document.getElementById('cd-days').innerText = Math.floor(dist / (1000*60*60*24));
        document.getElementById('cd-hours').innerText = Math.floor((dist % (1000*60*60*24)) / (1000*60*60));
        document.getElementById('cd-minutes').innerText = Math.floor((dist % (1000*60*60)) / (1000*60));
        document.getElementById('cd-seconds').innerText = Math.floor((dist % (1000*60)) / 1000);
      }, 1000);
    }

    // 6. CEK NAMA (INTEGRASI GOOGLE SHEETS)
    function cekNama() {
      const nama = document.getElementById('cekInput').value.trim();
      const btn = document.getElementById('btnCek');
      const res = document.getElementById('cekResult');
      
      res.className = 'result-box'; res.style.display='none';
      
      if(!nama) {
        res.className = 'result-box error'; res.innerHTML = '⚠️ Masukkan nama dulu!'; res.style.display='block';
        return;
      }

      btn.disabled = true; btn.innerText = '...';
      
      // PENTING: Ganti URL Web App Apps Script Anda di sini jika menggunakan metode fetch
      // Atau gunakan google.script.run jika di-hosting di Apps Script
      // Untuk GitHub Pages, kita harus pakai fetch ke Web App URL
      
      // CONTOH IMPLEMENTASI FETCH KE APPS SCRIPT WEB APP:
      const APPS_SCRIPT_URL = 'MASUKKAN_URL_WEB_APP_APPS_SCRIPT_ANDA_DISINI';
      
      fetch(APPS_SCRIPT_URL, {
        method: 'POST',
        body: JSON.stringify({ action: 'cekNama', nama: nama }),
        headers: { 'Content-Type': 'application/json' }
      })
      .then(r => r.json())
      .then(data => {
        btn.disabled = false; btn.innerText = 'Cek';
        if(data.error) { res.className='result-box error'; res.innerHTML=data.error; res.style.display='block'; return; }
        
        if(!data.found) {
          res.className='result-box not-found'; res.innerHTML='❌ Nama tidak ditemukan.'; res.style.display='block';
        } else if(data.single) {
          res.className='result-box found'; 
          res.innerHTML=`<strong>✅ ${data.nama}</strong><br>Status: ${data.status}`; res.style.display='block';
        } else {
          let html = '<div style="font-weight:bold;margin-bottom:10px;">🔍 Kami menemukan beberapa nama:</div>';
          data.candidates.forEach(c => { html += `<div style="padding:8px;border-bottom:1px solid #eee;">${c.nama} (${c.status})</div>`; });
          res.className='result-box found'; res.innerHTML=html; res.style.display='block';
        }
      })
      .catch(e => {
        btn.disabled=false; btn.innerText='Cek'; res.className='result-box error'; res.innerHTML='Gagal terhubung ke server.'; res.style.display='block';
      });
    }

    // 7. SUBMIT FORM
    function kirimKonfirmasi() {
      const data = {
        nama: document.getElementById('confNama').value,
        status: document.getElementById('confStatus').value,
        keterangan: document.getElementById('confUcapan').value
      };
      const btn = document.getElementById('btnSubmit');
      const res = document.getElementById('submitResult');
      
      if(!data.nama) { alert('Nama wajib diisi'); return; }
      
      btn.disabled=true; btn.innerText='Mengirim...';
      
      const APPS_SCRIPT_URL = 'MASUKKAN_URL_WEB_APP_APPS_SCRIPT_ANDA_DISINI';
      
      fetch(APPS_SCRIPT_URL, {
        method: 'POST',
        body: JSON.stringify({ action: 'konfirmasi', ...data }),
        headers: { 'Content-Type': 'application/json' }
      })
      .then(r => r.json())
      .then(r => {
        btn.disabled=false; btn.innerText='Kirim Konfirmasi';
        res.className = r.success ? 'result-box found' : 'result-box error';
        res.innerHTML = r.message; res.style.display='block';
        if(r.success) document.getElementById('confNama').value='';
      })
      .catch(e => {
        btn.disabled=false; btn.innerText='Kirim Konfirmasi';
        res.className='result-box error'; res.innerHTML='Gagal mengirim.'; res.style.display='block';
      });
    }

    // INIT
    window.onload = () => {
      initGuestName();
      document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));
    };
  </script>
</body>
</html>
